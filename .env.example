# Supabase (required for auth and protected shell in development)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. When set, todo assignees load from all Auth users (admin API).
# Keep secret — never NEXT_PUBLIC_. Dashboard → Settings → API → service_role
# SUPABASE_SERVICE_ROLE_KEY=

# Without service role: use Table Editor → household_members instead.

# Optional later: other server-only secrets must NOT use NEXT_PUBLIC_

# Web Push (generate with: pnpm exec web-push generate-vapid-keys)
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:you@example.com

# Register the PWA service worker during `next dev` (needed for Web Push testing).
# Restart `pnpm dev` after changing. Omit for faster dev without a worker.
# ENABLE_PWA_IN_DEV=true

# Secured cron for stale-task reminders: GET or POST /api/cron/stale-tasks with
# Authorization: Bearer $CRON_SECRET
# CRON_SECRET=
