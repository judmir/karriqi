# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/.open-next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# PWA service worker (generated on `pnpm build`)
/public/sw.js
/public/workbox-*.js
/public/worker-*.js

# vercel
.vercel

# Supabase CLI local cache (per-machine)
supabase/.temp/

# Cloudflare Wrangler local state/cache
.wrangler/

# typescript
*.tsbuildinfo
next-env.d.ts
cloudflare-env.d.ts
